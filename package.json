{
  "name": "junction",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "npx turbo run dev",
    "dev:frontend": "npx turbo run dev --filter=./apps/frontend",
    "dev:backend": "npx turbo run dev --filter=./apps/backend",
    "start": "npx turbo run start",
    "build": "npx turbo run build",
    "build:packages": "npx turbo run build --filter=./packages/*",
    "livekit": "pnpm livekit:up",
    "livekit:up": "docker compose -f infra/livekit/docker-compose.yml up -d",
    "livekit:down": "docker compose -f infra/livekit/docker-compose.yml down",
    "livekit:restart": "pnpm livekit:down && pnpm livekit:up",
    "livekit:logs": "docker compose -f infra/livekit/docker-compose.yml logs -f --tail=200"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.18.3",
  "devDependencies": {
    "dotenv": "^17.2.3",
    "handlebars": "^4.7.8",
    "tsx": "^4.20.6",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "viem": "^2.38.6"
  },
  "pnpm": {
    "overrides": {
      "@tiptap/core": "^3.14.0",
      "@tiptap/pm": "^3.14.0",
      "@tiptap/vue-3": "^3.14.0"
    }
  }
}
